body {
    background-color: blue;
    background-image: linear-gradient(to bottom, darkblue, green);
    background-repeat: no-repeat;
    font-family: Arial; sans-serif;
}
.page-header {
    background-image: linear-gradient(to right, purple, coral);
    /*background-image: url("flower.jpg);*/
    border-radius: 0px;
    text-align: center;
    color: white;
}
.fact-card {
    background-color: midnightblue;
    border-radius: 12px;
    color: white;
}
.fact-card h2 {
    color: coral;
}
.star {
    width: 60px;
    height: 60px;
    background-color: yellow;
}
